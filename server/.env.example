NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/foodbridge

# JWT
JWT_SECRET=change_this_to_random_256bit_hex_secret_key_1
JWT_REFRESH_SECRET=change_this_to_random_256bit_hex_secret_key_2

# Email (Gmail SMTP - enable App Password in Google Account)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=noreply@foodbridge.app
EMAIL_PASS=your_gmail_app_password

# App
CLIENT_URL=exp://localhost:8081
ADMIN_EMAIL=admin@foodbridge.app
